{
  "name": "cash-safe-monitor",
  "version": "1.0.0",
  "description": "Monitoring system for ether.fi Cash Safe LTV Health",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:reseed": "tsx src/scripts/reseed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "bullmq": "^5.25.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.34.0",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
