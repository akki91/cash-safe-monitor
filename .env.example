# Scroll RPC (required — must point to a Scroll chain RPC endpoint)
RPC_URL=https://rpc.ankr.com/scroll/YOUR_API_KEY

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5434/cash_monitor

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Contract Addresses (Scroll)
USER_SAFE_LENS_ADDRESS=0x7DA874f3BacA1A8F0af27E5ceE1b8C66A772F84E

# Safe Addresses CSV
SAFE_ADDRESSES_CSV=./data/safe_addresses.csv

# Polling
POLL_INTERVAL_MS=900000ms
MULTICALL_BATCH_SIZE=100

# RPC Resilience
RPC_RETRIES=3
RPC_RETRY_DELAY_MS=1000
BATCH_DELAY_MS=100

# Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_COOLDOWN_MINUTES=15

# API
API_PORT=3000
API_HOST=0.0.0.0

